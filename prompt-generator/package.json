{
  "name": "prompt-generator",
  "version": "2.3.0",
  "description": "Mega-prompt v2.3 generator: intent-locked templates, locale-aware defaults, deterministic 6-criterion scoring with repair loop, discriminated-union output.",
  "type": "module",
  "main": "dist/pipeline.js",
  "bin": {
    "generate-prompt": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "cli": "tsx src/cli.ts",
    "serve": "tsx src/server.ts",
    "start": "node dist/server.js",
    "test": "tsx src/test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
